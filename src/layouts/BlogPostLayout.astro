---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/helpers';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { title, description, pubDate, tags } = Astro.props;
---

<BaseLayout title={title} description={description} article={true}>
  <article class="container-narrow">
    <header class="post-header section">
      <h1 class="post-title">{title}</h1>

      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>
          {formatDate(pubDate)}
        </time>
      </div>

      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => (
            <a href={`/blog?tag=${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/blog" class="back-link">← Back to Blog</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-header {
    text-align: center;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .post-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-sm);
  }

  .separator {
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    background-color: var(--color-bg-secondary);
    color: var(--color-accent);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: all var(--transition);
  }

  .tag:hover {
    background-color: var(--color-accent);
    color: white;
  }

  .post-content {
    font-size: var(--text-lg);
    line-height: 1.8;
  }

  .post-content :global(h2) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .post-content :global(h3) {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .post-content :global(h2:first-child),
  .post-content :global(h3:first-child) {
    margin-top: 0;
    border-top: none;
    padding-top: 0;
  }

  .post-content :global(img) {
    border-radius: var(--border-radius);
    margin: var(--space-lg) 0;
  }

  .post-content :global(pre) {
    margin: var(--space-md) 0;
    overflow-x: auto;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-md) 0;
  }

  .post-content :global(th),
  .post-content :global(td) {
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .post-content :global(th) {
    background-color: var(--color-bg-secondary);
    font-weight: 600;
  }

  .post-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    color: var(--color-accent);
    font-weight: 600;
    transition: all var(--transition);
  }

  .back-link:hover {
    color: var(--color-accent-hover);
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: var(--text-3xl);
    }

    .post-content {
      font-size: var(--text-base);
    }
  }
</style>
