---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact - Junseo Choi"
  description="Get in touch with Junseo Choi for research collaborations, questions, or project inquiries."
  pageTitle="Contact"
>
  <div class="contact-content">
    <div class="contact-intro">
      <p>
        I'm always interested in discussing research ideas, potential collaborations, or
        questions about my work. Feel free to reach out through any of the channels below.
      </p>
    </div>

    <div class="contact-methods">
      <div class="contact-card">
        <div class="contact-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>
        <h3>Email</h3>
        <p class="contact-detail">
          <a href="mailto:litterrariuschwy@gmail.com">litterrariuschwy@gmail.com</a>
        </p>
        <p class="contact-description">
          Best for research inquiries, collaboration proposals, or detailed questions.
        </p>
      </div>

      <div class="contact-card">
        <div class="contact-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
        </div>
        <h3>GitHub</h3>
        <p class="contact-detail">
          <a href="https://github.com/ddinggul" target="_blank" rel="noopener noreferrer">
            github.com/ddinggul
          </a>
        </p>
        <p class="contact-description">
          Check out my code, projects, and open-source contributions.
        </p>
      </div>

      <div class="contact-card">
        <div class="contact-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </div>
        <h3>Instagram</h3>
        <p class="contact-detail">
          <a href="https://instagram.com/2dinggul_myroom" target="_blank" rel="noopener noreferrer">
            @2dinggul_myroom
          </a>
        </p>
        <p class="contact-description">
          Connect for more informal updates and insights.
        </p>
      </div>
    </div>

    <div class="additional-info">
      <h2>Future Contact Options</h2>
      <p>
        I'm currently working on setting up additional professional profiles:
      </p>
      <ul>
        <li><strong>Google Scholar:</strong> Academic publications and citations (coming soon)</li>
        <li><strong>ORCID:</strong> Researcher identifier and publication tracking (coming soon)</li>
        <li><strong>LinkedIn:</strong> Professional network and career updates (coming soon)</li>
      </ul>
    </div>

    <div class="response-time">
      <h2>Response Time</h2>
      <p>
        I typically respond to emails within 2-3 business days. If your inquiry is time-sensitive,
        please mention it in the subject line. For urgent matters related to ongoing collaborations,
        feel free to follow up if you haven't heard back within a week.
      </p>
    </div>

    <div class="collaboration-interests">
      <h2>Collaboration Interests</h2>
      <p>I'm particularly interested in collaborations involving:</p>
      <ul>
        <li>Cross-linguistic prosody research</li>
        <li>Computational phonetics and speech analysis</li>
        <li>AI applications for language learning</li>
        <li>L1-L2 speech comparison and transfer studies</li>
        <li>Development of open-source linguistic tools</li>
        <li>Interdisciplinary projects combining linguistics, CS, and education</li>
      </ul>
      <p>
        If your project aligns with these areas, I'd love to hear from you!
      </p>
    </div>
  </div>
</PageLayout>

<style>
  .contact-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .contact-intro {
    text-align: center;
    font-size: var(--text-lg);
    margin-bottom: var(--space-2xl);
    color: var(--color-text-secondary);
  }

  .contact-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .contact-card {
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    text-align: center;
    transition: all var(--transition);
  }

  .contact-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
  }

  .contact-icon {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-md);
    color: var(--color-accent);
  }

  .contact-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }

  .contact-detail {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
  }

  .contact-detail a {
    color: var(--color-accent);
    font-weight: 600;
    word-break: break-word;
  }

  .contact-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .additional-info,
  .response-time,
  .collaboration-interests {
    margin-bottom: var(--space-2xl);
    padding: var(--space-lg);
    background-color: var(--color-bg-secondary);
    border-radius: var(--border-radius);
    border-left: 4px solid var(--color-accent);
  }

  .additional-info h2,
  .response-time h2,
  .collaboration-interests h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-md);
    color: var(--color-accent);
  }

  .additional-info p,
  .response-time p,
  .collaboration-interests p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .additional-info ul,
  .collaboration-interests ul {
    margin-top: var(--space-sm);
  }

  .additional-info li,
  .collaboration-interests li {
    margin-bottom: var(--space-xs);
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .contact-methods {
      grid-template-columns: 1fr;
    }
  }
</style>
