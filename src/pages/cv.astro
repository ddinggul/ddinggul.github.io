---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="CV - Junseo Choi"
  description="Academic CV and professional experience of Junseo Choi, researcher in computational linguistics and phonetics."
  pageTitle="Curriculum Vitae"
>
  <div class="cv-content">
    <section class="cv-section">
      <h2>Education</h2>
      <div class="cv-item">
        <div class="cv-item-header">
          <h3>PhD in Linguistics</h3>
          <span class="cv-date">Expected 2026</span>
        </div>
        <p class="cv-institution">[University Name]</p>
        <p class="cv-detail">
          Dissertation: Computational Analysis of Prosodic Patterns in L2 Speech Acquisition
        </p>
      </div>

      <div class="cv-item">
        <div class="cv-item-header">
          <h3>MA in Linguistics</h3>
          <span class="cv-date">2022</span>
        </div>
        <p class="cv-institution">[University Name]</p>
        <p class="cv-detail">
          Thesis: Cross-linguistic Comparison of Prosodic Structures in Korean and English
        </p>
      </div>

      <div class="cv-item">
        <div class="cv-item-header">
          <h3>BA in English Language and Literature</h3>
          <span class="cv-date">2020</span>
        </div>
        <p class="cv-institution">[University Name]</p>
        <p class="cv-detail">Concentration in Linguistics and Computational Methods</p>
      </div>
    </section>

    <section class="cv-section">
      <h2>Research Interests</h2>
      <ul class="research-list">
        <li>Experimental Phonetics and Acoustic Phonetics</li>
        <li>Computational Linguistics and Natural Language Processing</li>
        <li>Speech Prosody and Intonation</li>
        <li>L1-L2 Speech Analysis and Language Transfer</li>
        <li>AI for Language Learning and Educational Technology</li>
        <li>Contrastive Learning Approaches to Phonetic Analysis</li>
      </ul>
    </section>

    <section class="cv-section">
      <h2>Skills</h2>

      <div class="skills-grid">
        <div class="skill-category">
          <h3>Programming</h3>
          <ul>
            <li>Python (advanced)</li>
            <li>R (proficient)</li>
            <li>JavaScript/TypeScript (proficient)</li>
            <li>Praat Scripting</li>
          </ul>
        </div>

        <div class="skill-category">
          <h3>Phonetic Analysis</h3>
          <ul>
            <li>Praat</li>
            <li>Parselmouth</li>
            <li>Montreal Forced Aligner</li>
            <li>ELAN</li>
          </ul>
        </div>

        <div class="skill-category">
          <h3>ML/AI</h3>
          <ul>
            <li>PyTorch, TensorFlow</li>
            <li>scikit-learn</li>
            <li>Transformers, LangChain</li>
            <li>OpenAI API, Anthropic API</li>
          </ul>
        </div>

        <div class="skill-category">
          <h3>Data & Analysis</h3>
          <ul>
            <li>NumPy, Pandas, SciPy</li>
            <li>tidyverse, ggplot2</li>
            <li>Statistical modeling (linear models, mixed effects)</li>
            <li>Signal processing (librosa, scipy.signal)</li>
          </ul>
        </div>

        <div class="skill-category">
          <h3>Development</h3>
          <ul>
            <li>Git/GitHub</li>
            <li>React, Next.js, Astro</li>
            <li>FastAPI, Flask</li>
            <li>SQL, PostgreSQL</li>
          </ul>
        </div>

        <div class="skill-category">
          <h3>Languages</h3>
          <ul>
            <li>Korean (native)</li>
            <li>English (fluent)</li>
            <li>Japanese (reading proficiency)</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="cv-section">
      <h2>Selected Projects</h2>

      <div class="cv-item">
        <h3>Prosody Analysis with Contrastive Learning</h3>
        <p>
          Developed a computational framework for analyzing prosodic patterns using contrastive
          learning techniques. Compared pitch contours, rhythm, and stress patterns across Korean
          and English speakers to identify distinctive prosodic features.
        </p>
        <p class="cv-tech"><strong>Technologies:</strong> Python, PyTorch, Praat, Parselmouth</p>
      </div>

      <div class="cv-item">
        <h3>AI Vocabulary Learning System</h3>
        <p>
          Built an intelligent vocabulary learning application with adaptive spaced repetition,
          contextual example generation, and personalized feedback using large language models.
        </p>
        <p class="cv-tech"><strong>Technologies:</strong> TypeScript, Next.js, PostgreSQL, OpenAI API</p>
      </div>

      <div class="cv-item">
        <h3>Grammar Correction & Sentence Evaluation</h3>
        <p>
          Created an AI-powered system providing detailed grammatical feedback for language learners,
          leveraging LLMs for error detection, correction suggestions, and explanations.
        </p>
        <p class="cv-tech"><strong>Technologies:</strong> Python, FastAPI, React, OpenAI API</p>
      </div>
    </section>

    <section class="cv-section">
      <h2>Publications</h2>
      <p class="cv-placeholder">
        <em>Publications to be listed upon completion of ongoing research projects.</em>
      </p>
    </section>

    <section class="cv-section">
      <h2>Conference Presentations</h2>
      <p class="cv-placeholder">
        <em>Conference presentations to be listed as research progresses.</em>
      </p>
    </section>

    <section class="cv-section">
      <h2>Awards & Honors</h2>
      <p class="cv-placeholder">
        <em>Awards and honors to be listed.</em>
      </p>
    </section>

    <section class="cv-section">
      <h2>Teaching & Mentoring</h2>
      <p class="cv-placeholder">
        <em>Teaching experience and mentoring roles to be listed.</em>
      </p>
    </section>

    <div class="cv-download">
      <p>
        <em>A downloadable PDF version of this CV will be available soon.</em>
      </p>
    </div>
  </div>
</PageLayout>

<style>
  .cv-content {
    line-height: 1.8;
  }

  .cv-section {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .cv-section:last-of-type {
    border-bottom: none;
  }

  .cv-section h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-lg);
    color: var(--color-accent);
  }

  .cv-item {
    margin-bottom: var(--space-lg);
  }

  .cv-item:last-child {
    margin-bottom: 0;
  }

  .cv-item-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-md);
    margin-bottom: var(--space-xs);
  }

  .cv-item h3 {
    font-size: var(--text-xl);
    margin: 0;
  }

  .cv-date {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
    white-space: nowrap;
  }

  .cv-institution {
    color: var(--color-text-secondary);
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .cv-detail {
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  .cv-tech {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-xs);
  }

  .research-list {
    columns: 1;
    column-gap: var(--space-xl);
  }

  .research-list li {
    margin-bottom: var(--space-sm);
    color: var(--color-text-secondary);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
  }

  .skill-category h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
    color: var(--color-text-primary);
  }

  .skill-category ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .skill-category li {
    padding: var(--space-xs) 0;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .cv-placeholder {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .cv-download {
    text-align: center;
    margin-top: var(--space-2xl);
    padding: var(--space-lg);
    background-color: var(--color-bg-secondary);
    border-radius: var(--border-radius);
  }

  @media (max-width: 768px) {
    .cv-item-header {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .research-list {
      columns: 1;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
