---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Junseo Choi - Computational Linguistics & Phonetics Researcher"
  description="Junseo Choi's personal website. Research in experimental phonetics, acoustic phonetics, and computational linguistics with a focus on speech prosody and AI for language learning."
>
  <!-- Hero Section -->
  <section class="hero section">
    <div class="container-narrow">
      <div class="hero-content">
        <h1 class="hero-title">
          <span class="lang-en">Junseo Choi</span>
          <span class="lang-ko">최준서</span>
        </h1>
        <p class="hero-subtitle">
          <span class="lang-en">Computational Linguistics & Phonetics Researcher</span>
          <span class="lang-ko">전산언어학 및 음성학 연구자</span>
        </p>
        <p class="hero-description">
          <span class="lang-en">
            Exploring the computational analysis of speech and language, with a focus on
            <strong>prosody</strong>, <strong>L1-L2 speech comparison</strong>, and
            <strong>AI-based language learning applications</strong>.
          </span>
          <span class="lang-ko">
            <strong>운율</strong>, <strong>모국어-제2언어 음성 비교</strong>, 그리고
            <strong>AI 기반 언어 학습 애플리케이션</strong>에 중점을 둔 음성 및 언어의 전산 분석을 연구하고 있습니다.
          </span>
        </p>

        <div class="hero-keywords lang-en">
          <span class="keyword">Experimental Phonetics</span>
          <span class="keyword">Acoustic Phonetics</span>
          <span class="keyword">Computational Linguistics</span>
          <span class="keyword">Speech Prosody</span>
          <span class="keyword">AI for Language Learning</span>
        </div>

        <div class="hero-keywords lang-ko">
          <span class="keyword">실험음성학</span>
          <span class="keyword">음향음성학</span>
          <span class="keyword">전산언어학</span>
          <span class="keyword">음성 운율</span>
          <span class="keyword">AI 언어 학습</span>
        </div>

        <div class="hero-actions">
          <span class="lang-en">
            <Button href="/projects">View Projects</Button>
            <Button href="/blog" variant="outline">Read Blog</Button>
          </span>
          <span class="lang-ko">
            <Button href="/projects">프로젝트 보기</Button>
            <Button href="/blog" variant="outline">블로그 읽기</Button>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- About Preview Section -->
  <section class="about-preview section">
    <div class="container-narrow">
      <h2 class="lang-en">About Me</h2>
      <h2 class="lang-ko">소개</h2>

      <div class="lang-en">
        <p>
          I am interested in experimental phonetics, acoustic phonetics, and computational linguistics.
          My work focuses on the computational analysis of speech and language data, especially prosody,
          L1-L2 speech comparison, and AI-based language learning applications.
        </p>
        <p>
          I combine rigorous linguistic analysis with modern computational methods to understand
          how humans produce and perceive speech, and how technology can support language learning.
        </p>
        <Button href="/about" variant="secondary">Learn More About Me</Button>
      </div>

      <div class="lang-ko">
        <p>
          저는 실험음성학, 음향음성학, 전산언어학에 관심을 가지고 있습니다.
          특히 운율, 모국어-제2언어 음성 비교, AI 기반 언어 학습 애플리케이션 등 음성 및 언어 데이터의 전산 분석에 집중하고 있습니다.
        </p>
        <p>
          언어학적 분석과 현대적인 전산 방법론을 결합하여 인간이 음성을 생성하고 인식하는 방식, 그리고 기술이 언어 학습을 어떻게 지원할 수 있는지를 연구합니다.
        </p>
        <Button href="/about" variant="secondary">더 알아보기</Button>
      </div>
    </div>
  </section>

  <!-- Recent Posts Section -->
  {recentPosts.length > 0 && (
    <section class="recent-posts section">
      <div class="container">
        <h2 class="section-title lang-en">Recent Blog Posts</h2>
        <h2 class="section-title lang-ko">최근 블로그 포스트</h2>
        <div class="posts-grid">
          {recentPosts.map(post => (
            <Card href={`/blog/${post.slug}`} class="post-card">
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="post-meta">
                <time>{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                {post.data.tags.length > 0 && (
                  <div class="tags">
                    {post.data.tags.slice(0, 2).map(tag => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </Card>
          ))}
        </div>
        <div class="view-all">
          <span class="lang-en">
            <Button href="/blog" variant="secondary">View All Posts</Button>
          </span>
          <span class="lang-ko">
            <Button href="/blog" variant="secondary">모든 포스트 보기</Button>
          </span>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: var(--text-5xl);
    font-weight: 800;
    margin-bottom: var(--space-sm);
    background: linear-gradient(135deg, var(--color-text-primary), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: var(--text-2xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
    font-weight: 600;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .hero-description strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .hero-keywords {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-xl);
  }

  .keyword {
    background-color: var(--color-bg-secondary);
    color: var(--color-text-primary);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: 500;
    border: 1px solid var(--color-border);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .about-preview {
    background-color: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .about-preview h2 {
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .about-preview p {
    font-size: var(--text-lg);
    line-height: 1.8;
    margin-bottom: var(--space-md);
    text-align: center;
  }

  .about-preview :global(.button) {
    display: block;
    margin: var(--space-lg) auto 0;
    max-width: max-content;
  }

  .recent-posts {
    padding-bottom: var(--space-2xl);
  }

  .section-title {
    text-align: center;
    font-size: var(--text-3xl);
    margin-bottom: var(--space-xl);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .post-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-xs);
  }

  .post-card p {
    font-size: var(--text-base);
    margin-bottom: var(--space-sm);
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

  .tags {
    display: flex;
    gap: var(--space-xs);
  }

  .tag {
    color: var(--color-accent);
    font-weight: 500;
  }

  .view-all {
    text-align: center;
    margin-top: var(--space-xl);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: var(--text-4xl);
    }

    .hero-subtitle {
      font-size: var(--text-xl);
    }

    .hero-description {
      font-size: var(--text-base);
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
