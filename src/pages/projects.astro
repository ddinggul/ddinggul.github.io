---
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/Card.astro';

const projects = [
  {
    title: 'Prosody Analysis with Contrastive Learning',
    description: 'A computational framework for analyzing prosodic patterns in speech using contrastive learning techniques. Compares pitch contours, rhythm, and stress patterns across different speakers and languages to identify distinctive prosodic features.',
    stack: ['Python', 'PyTorch', 'Praat', 'Parselmouth'],
    status: 'In Progress',
    category: 'Research',
    github: '#',
  },
  {
    title: 'Grammar Correction & Sentence Evaluation',
    description: 'An AI-powered system that provides detailed grammatical feedback and evaluates sentence quality for language learners. Leverages large language models to identify errors, suggest corrections, and explain grammatical rules in context.',
    stack: ['Python', 'OpenAI API', 'FastAPI', 'React'],
    status: 'Active',
    category: 'Application',
    github: '#',
    demo: '#',
  },
  {
    title: 'LLM-based Narrative Structure Modeling',
    description: 'Exploring how large language models understand and generate narrative structures. Analyzes story coherence, character development, and plot progression using computational methods to model narrative understanding.',
    stack: ['Python', 'Transformers', 'LangChain', 'Jupyter'],
    status: 'Experimental',
    category: 'Research',
    github: '#',
  },
  {
    title: 'AI Vocabulary Learning System',
    description: 'An intelligent vocabulary learning application that adapts to individual learning patterns. Uses spaced repetition, contextual examples, and pronunciation guidance to optimize vocabulary acquisition for language learners.',
    stack: ['TypeScript', 'Next.js', 'PostgreSQL', 'OpenAI API'],
    status: 'In Development',
    category: 'Application',
    github: '#',
  },
];

const categories = ['All', ...Array.from(new Set(projects.map(p => p.category)))];
---

<PageLayout
  title="Projects - Junseo Choi"
  description="Research projects and applications in computational linguistics, phonetics, and AI for language learning by Junseo Choi."
  pageTitle="Projects"
  wide={true}
>
  <div class="projects-intro">
    <p>
      A collection of research projects and applications exploring computational linguistics,
      phonetic analysis, and AI-powered language learning tools.
    </p>
  </div>

  <div class="filters">
    <button class="filter-btn active" data-category="All">All</button>
    {categories.slice(1).map(category => (
      <button class="filter-btn" data-category={category}>{category}</button>
    ))}
  </div>

  <div class="projects-grid">
    {projects.map(project => (
      <Card class="project-card" data-category={project.category}>
        <div class="project-header">
          <h3>{project.title}</h3>
          <span class={`status status-${project.status.toLowerCase().replace(' ', '-')}`}>
            {project.status}
          </span>
        </div>

        <p class="project-description">{project.description}</p>

        <div class="project-stack">
          {project.stack.map(tech => (
            <span class="tech-tag">{tech}</span>
          ))}
        </div>

        <div class="project-links">
          {project.github && (
            <a href={project.github} class="project-link" aria-label="View on GitHub">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
              </svg>
              GitHub
            </a>
          )}
          {project.demo && (
            <a href={project.demo} class="project-link" aria-label="View demo">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 16 16 12 12 8"></polyline>
                <line x1="8" y1="12" x2="16" y2="12"></line>
              </svg>
              Demo
            </a>
          )}
        </div>
      </Card>
    ))}
  </div>
</PageLayout>

<style>
  .projects-intro {
    text-align: center;
    margin-bottom: var(--space-xl);
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .filters {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .filter-btn {
    background-color: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: var(--space-xs) var(--space-md);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition);
  }

  .filter-btn:hover,
  .filter-btn.active {
    background-color: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--space-lg);
  }

  .project-card {
    display: flex;
    flex-direction: column;
  }

  .project-card[data-hidden="true"] {
    display: none;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .project-header h3 {
    font-size: var(--text-xl);
    margin: 0;
    flex: 1;
  }

  .status {
    font-size: var(--text-xs);
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    font-weight: 600;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .status-active {
    background-color: #10b981;
    color: white;
  }

  .status-in-progress,
  .status-in-development {
    background-color: #f59e0b;
    color: white;
  }

  .status-experimental {
    background-color: #8b5cf6;
    color: white;
  }

  .project-description {
    flex: 1;
    margin-bottom: var(--space-md);
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .tech-tag {
    background-color: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: var(--text-xs);
    font-weight: 500;
    border: 1px solid var(--color-border);
  }

  .project-links {
    display: flex;
    gap: var(--space-sm);
    margin-top: auto;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .project-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-accent);
    font-weight: 500;
    font-size: var(--text-sm);
    transition: color var(--transition);
  }

  .project-link:hover {
    color: var(--color-accent-hover);
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const projectCards = document.querySelectorAll('.project-card');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const category = button.getAttribute('data-category');

        // Update active state
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        // Filter projects
        projectCards.forEach(card => {
          const cardCategory = card.getAttribute('data-category');
          if (category === 'All' || cardCategory === category) {
            card.removeAttribute('data-hidden');
          } else {
            card.setAttribute('data-hidden', 'true');
          }
        });
      });
    });
  });
</script>
